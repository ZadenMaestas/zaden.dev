---
import Main from "./Main.astro";
import NavBar from "../components/NavBar.astro";

const { frontmatter } = Astro.props;
const date = new Date(frontmatter.pubDate).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric'
});
---
<Main title={`${frontmatter.title} — Zaden Maestas`} description={frontmatter.description}>
    <NavBar />

    <div class="post__container">
        <a class="post__back" href="/blog">← Back to Blog</a>

        <header class="post__header">
            <div class="post__meta">
                <time class="post__date">{date}</time>
                {frontmatter.tags && (
                    <div class="post__tags">
                        {frontmatter.tags.map((tag: string) => (
                            <span class="post__tag">{tag}</span>
                        ))}
                    </div>
                )}
            </div>
            <h1 class="post__title">{frontmatter.title}</h1>
            <p class="post__description">{frontmatter.description}</p>
            <p class="post__author">By {frontmatter.author}</p>
        </header>

        <hr class="post__divider" />

        <article class="post__body">
            <slot />
        </article>
    </div>
</Main>

<style>
    .post__container {
        max-width: 720px;
        margin: 0 auto;
        padding: 40px 20px 100px;
    }

    .post__back {
        display: inline-block;
        color: #6030b1;
        font-weight: 700;
        font-size: 0.9rem;
        margin-bottom: 36px;
        transition: opacity 0.2s ease;
    }

    .post__back:hover {
        opacity: 0.7;
    }

    /* Header */
    .post__header {
        margin-bottom: 32px;
    }

    .post__meta {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 16px;
    }

    .post__date {
        font-size: 0.8rem;
        color: #999;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .post__tags {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .post__tag {
        font-size: 0.75rem;
        background: #f0eaff;
        color: #6030b1;
        padding: 2px 10px;
        border-radius: 50px;
        font-weight: 600;
    }

    .post__title {
        text-align: left;
        font-size: 2.2rem;
        line-height: 1.2;
        color: #242424;
        margin-bottom: 12px;
    }

    .post__description {
        font-size: 1.1rem;
        color: #555;
        margin-bottom: 12px;
        line-height: 1.6;
    }

    .post__author {
        font-size: 0.9rem;
        color: #888;
        font-weight: 700;
    }

    .post__divider {
        border: none;
        border-top: 1px solid #e8e8e8;
        margin-bottom: 40px;
    }

    /* Prose styles for rendered markdown */
    .post__body :global(h1),
    .post__body :global(h2),
    .post__body :global(h3),
    .post__body :global(h4) {
        text-align: left;
        color: #242424;
        margin: 2rem 0 0.75rem;
        line-height: 1.3;
    }

    .post__body :global(h1) { font-size: 1.8rem; }
    .post__body :global(h2) { font-size: 1.4rem; }
    .post__body :global(h3) { font-size: 1.15rem; }

    .post__body :global(p) {
        color: #333;
        line-height: 1.8;
        margin-bottom: 1.25rem;
    }

    .post__body :global(ul),
    .post__body :global(ol) {
        padding-left: 1.5rem;
        margin-bottom: 1.25rem;
        color: #333;
        line-height: 1.8;
    }

    .post__body :global(li) {
        list-style: revert;
        margin-bottom: 0.4rem;
    }

    .post__body :global(a) {
        color: #6030b1;
        font-weight: 600;
        text-decoration: underline;
        text-underline-offset: 3px;
    }

    .post__body :global(code) {
        font-family: 'Courier New', Courier, monospace;
        background: #f4f0fc;
        color: #6030b1;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.9em;
    }

    .post__body :global(pre) {
        background: #1e1e2e;
        color: #cdd6f4;
        padding: 20px 24px;
        border-radius: 10px;
        overflow-x: auto;
        margin-bottom: 1.5rem;
        font-size: 0.9rem;
        line-height: 1.6;
    }

    .post__body :global(pre code) {
        background: none;
        color: inherit;
        padding: 0;
        font-size: inherit;
    }

    .post__body :global(blockquote) {
        border-left: 4px solid #6030b1;
        padding: 8px 20px;
        margin: 1.5rem 0;
        background: #f8f5ff;
        border-radius: 0 8px 8px 0;
        color: #555;
        font-style: italic;
    }

    .post__body :global(hr) {
        border: none;
        border-top: 1px solid #e8e8e8;
        margin: 2rem 0;
    }

    .post__body :global(img) {
        max-width: 100%;
        border-radius: 10px;
        margin: 1.5rem 0;
    }

    @media (max-width: 768px) {
        .post__title {
            font-size: 1.7rem;
        }
    }
</style>
