---
import {Icon} from 'astro-icon/components';

const {name, logo} = Astro.props;
---
<div class="language">
    <figure class="language__img--wrapper">
        <Icon class="language__img" name={logo}/>
    </figure>
    <span class="language__name">{name}</span>
</div>

<style>
    .language__img {
        width: 100%;
        max-width: 100px;
        font-size: 100px;
    }

    .language:hover .language__img {
        filter: brightness(80%);
        opacity: 0.86;
        transform: scale(0.9);
        transition: all 300ms ease;
    }

    .language {
        width: 25%;
        display: flex;
        justify-content: center;
        position: relative;
    }

    .language__img--wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 25px 16px;
    }


    .language__name {
        position: absolute;
        bottom: 0;
        transform: scale(0);
        transition: all 300ms ease;
        font-size: 20px;
        opacity: 0;
    }

    .language:hover .language__name {
        transform: scale(1);
        opacity: 1;
    }
</style>